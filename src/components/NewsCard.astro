---
const { post } = Astro.props;

const { Content } = await post.render();
const { image, purchaseLink, pubDate } = post.data;

const isFuture = pubDate && new Date(pubDate) > new Date();
---

<section class="card-container">
  <div class="card">
    {image && <img src={image} alt={post.data.title} class="card-image" />}
    <Content />
    {isFuture && purchaseLink && (
      <a href={purchaseLink} target="_blank" rel="noopener noreferrer" class="buy-btn">
        Kúpiť lístky
      </a>
    )}
  </div>
</section>

<style>
  .card-container {
    display: flex;
    flex-direction: column;
    gap: 1em;
    width: 100%;
  }

  .card {
    outline: 1px solid black;
    outline-offset: -1px;
    box-shadow: 5px 5px 0 black;
    transition:
      box-shadow 0.2s ease,
      translate 0.2s ease;
    translate: -2px -2px;
    padding: 1em;

    &:hover {
      box-shadow: 9px 9px 0 black;
      translate: -5px -5px;
    }
  }

  .card-image {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 1em;
  }

  .buy-btn {
    display: inline-block;
    margin-top: 1em;
    padding: 0.5em 1.25em;
    background: black;
    color: white;
    text-decoration: none;
    font-size: var(--step--1);
    font-family: inherit;
    transition: background 0.2s ease;

    &:hover {
      background: #333;
    }
  }
</style>
